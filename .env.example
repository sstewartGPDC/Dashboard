# ─── GPDC Dashboard configuration ───────────────────────────────────────
# Copy to `.env` and fill in. Never commit a real .env with secrets.

# Port the server listens on (behind your reverse proxy in hosted mode).
PORT=3000

# ── Mode ────────────────────────────────────────────────────────────────
# Set NODE_ENV=production for the hosted intranet deployment. This turns on
# strict security checks (secret required, secure cookies, proxy trust).
# Leave unset for local development / the desktop app.
# NODE_ENV=production

# ── Session secret (REQUIRED in hosted mode) ────────────────────────────
# Must be a strong, unique, random value of at least 32 characters.
# Generate one with:  openssl rand -base64 48
# The server REFUSES to start in hosted mode with a missing/weak/placeholder value.
SESSION_SECRET=

# ── Database driver ─────────────────────────────────────────────────────
# 'sqlite' (default, local/desktop) or 'postgres' (hosted intranet).
GPDC_DB_DRIVER=sqlite

# SQLite: directory holding database.sqlite (defaults to ./db)
# GPDC_DB_DIR=./db

# Postgres (when GPDC_DB_DRIVER=postgres): a connection string OR discrete vars.
# DATABASE_URL=postgres://user:password@host:5432/gpdc
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=gpdc

# ── TLS / reverse proxy ─────────────────────────────────────────────────
# Set these when TLS terminates at an upstream proxy/load balancer.
# GPDC_TRUST_PROXY=true     # trust X-Forwarded-* (auto-on in hosted mode)
# GPDC_BEHIND_TLS=true      # mark cookies Secure + send HSTS header
# GPDC_FORCE_HTTPS=true     # redirect http→https

# ── Login lockout policy (optional overrides) ───────────────────────────
# GPDC_LOGIN_MAX_FAILED=5
# GPDC_LOGIN_WINDOW_MIN=15

# ── Initial admin password (seed only) ──────────────────────────────────
# REQUIRED when seeding a hosted/postgres database; optional for local sqlite
# (defaults to gpdc2025 with a warning). Change after first login regardless.
# GPDC_ADMIN_PASSWORD=
